// -*- mode: jsonc -*-
{
    "layer": "bottom",
    "height": 30,
    "margin-top": 0,
    "margin-right": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "reload_style_on_change": true,
    "modules-left": [
        "custom/spacer",
        "group/nixos",
        "group/settings",
        "custom/notification",
        "clock",
        "hyprland/workspaces",
        "cpu",
        "memory",
        "temperature",
        "hyprland/submap"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "bluetooth",
        "pulseaudio",
        "network",
        "backlight",
        "battery",
        "group/sandwich",
        "group/power",
        "custom/spacer"
    ],
    "group/sandwich": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 100,
            "transition-left-to-right": false,
            "children-class": "tray-drawer"
        },
        "modules": [
            "custom/sandwich",
            "tray"
        ]
    },
    "custom/sandwich": {
        "format": "َ°چœ",
        "tooltip": false
    },
    "group/settings": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 100,
            "transition-left-to-right": true,
            "children-class": "settings-drawer"
        },
        "modules": [
            "custom/settings",
            "custom/settings-wallpaper",
            "power-profiles-daemon",
            "idle_inhibitor",
            "custom/open-application"
        ]
    },
    "custom/settings": {
        "format": "ï€“",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "format": "({icon}:{windows})",
        "format-window-separator": " ",
        "window-rewrite-default": "َ±”¢",
        "window-rewrite": {
            "class<brave-browser>": "َ°–ں",
            "class<firefox>": "َ°ˆ¹",
            "class<google-chrome>": "َ°ٹ¯",
            "class<spotify>": "َ°“‡",
            "class<org.gnome.Nautilus>": "َ°‰“",
            "class<pix>": "َ±‡£",
            "class<steam>": "î´©",
            "class<kitty>": "î¯ٹ",
            "class<code>": "َ°¨‍",
            "class<signal>": "َ°چ©",
            "class<rofi>": "َ°Œ§",
            "class<obsidian>": "ïˆ™",
            "class<Github Desktop>": "َ°ٹ¤",
            "class<discord>": "ï‡؟",
            "class<Slack>": "َ°’±",
            "class<zoom>": "َ°•§",
            "class<vlc>": "َ°•¼",
            "class<MuseScore4>": "َ°½؛",
            "class<org.gnome.Calculator>": "َ°ƒ¬",
            "class<org.gnome.SystemMonitor>": "َ°،‌",
            "class<.virt-manager-wrapped>": "î©؛",
            "class<libreoffice-impress>": "ïچ؛",
            "class<libreoffice-writer": "ïچ¼",
            "class<libreoffice-calc": "ïچ¸",
            "class<libreoffice-base>": "ïچ·",
            "class<libreoffice-draw>": "ïچ¹",
            "class<libreoffice-math>": "ïچ»",
            "class<libreoffice-startcenter>": "ïچ¶",
            "class<soffice>": "َ°ˆ‡"
        },
        "show-special": true
    },
    "hyprland/window": {
        "format": "{title}",
        "format-alt": "{class}",
        "max-length": 40,
        "tooltip-format": "{title}\n{class}",
        "icon": true,
        "icon-size": 20,
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) :: (.*) :: Visual Studio Code": "$2 َ°ک¬ $1",
            "(.*) :: Visual Studio Code": "$1 َ°ک¬",
            "(.*) â€” LibreOffice Impress": "$1",
            "(.*) â€” LibreOffice Writer": "$1",
            "(.*) â€” LibreOffice Calc": "$1",
            "(.*) â€” LibreOffice Base": "$1",
            "(.*) â€” LibreOffice Draw": "$1",
            "(.*) â€” LibreOffice Math": "$1",
            "(.*) â€” LibreOffice": "$1"
        },
        "separate-outputs": true
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip-format-activated": "Idle Inhibitor is {status}",
        "tooltip-format-deactivated": "Idle Inhibitor is {status}",
        "format-icons": {
            "activated": "َ°ˆˆ",
            "deactivated": "َ°ˆ‰"
        },
        "start-activated": true
    },
    "clock": {
        "interval": 60,
        "tooltip": false,
        "format": "َ°¸— {0:%m-%d} َ°¥” {0:%H:%M}"
    },
    "cpu": {
        "format": "",
        "format-warning": "َ°کڑ {usage}%",
        "format-critical": "َ°کڑ {usage}%",
        "states": {
            "warning": 75,
            "critical": 90
        },
        "tooltip": false
    },
    "memory": {
        "format": "",
        "format-warning": "َ°چ› {percentage}%",
        "format-critical": "َ°چ› {percentage}%",
        "states": {
            "warning": 75,
            "critical": 90
        }
    },
    "temperature": {
        "critical-threshold": 70,
        "format": "",
        "format-critical": "َ±ƒ‚ {temperatureC}آ°C"
    },
    "backlight": {
        "format": "{icon}",
        "format-alt": "{icon} {percent}%",
        "tooltip-format": "{icon} {percent}%",
        "format-icons": {
            "default": [
                "َ°½¤",
                "َ°½¥",
                "َ°½£",
                "َ°½¦",
                "َ°½¢"
            ]
        }
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-alt": "{icon} {capacity}%",
        "format-plugged": "ï‡¦ {capacity}%",
        "format-icons": {
            "charging": [
                "َ°¢œ",
                "َ°‚†",
                "َ°‚‡",
                "َ°‚ˆ",
                "َ°¢‌",
                "َ°‚‰",
                "َ°¢‍",
                "َ°‚ٹ",
                "َ°‚‹",
                "َ°‚…"
            ],
            "default": [
                "َ°پ؛",
                "َ°پ»",
                "َ°پ¼",
                "َ°پ½",
                "َ°پ¾",
                "َ°پ؟",
                "َ°‚€",
                "َ°‚پ",
                "َ°‚‚",
                "َ°پ¹"
            ]
        },
        "tooltip-format": "{capacity}% {timeTo}"
    },
    "bluetooth": {
        "format": "ïٹ” {status}",
        "format-disabled": "َ°‚²",
        "format-on": "ïٹ”",
        "format-connected": "َ°‚±",
        "tooltip-format": "{controller_alias} {controller_address}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager",
        "on-click-right": "rfkill toggle bluetooth"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "{profile}",
        "tooltip": true,
        "format-icons": {
            "default": "َ±گ‹",
            "performance": "َ±گ‹",
            "balanced": "َ°—‘",
            "power-saver": "َ°Œھ"
        }
    },
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "{icon}",
        "tooltip-format": "{essid} {icon} {signalStrength}%",
        "format-disconnected": "َ°¤«",
        "format-icons": {
            "wifi": [
                "َ°¤¯",
                "َ°¤ں",
                "َ°¤¢",
                "َ°¤¥",
                "َ°¤¨"
            ],
            "ethernet": "َ°ˆپ"
        },
        "on-click": "kitty nmtui-connect"
    },
    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-muted": "{icon} {format_source}",
        "format-source": "ï„°",
        "format-source-muted": "ï„±",
        "format-icons": {
            "headphone": "َ°‹‹",
            "headphone-muted": "َ°ںژ",
            "hands-free": "َ°‹‹",
            "hands-free-muted": "َ°ںژ",
            "headset": "َ°‹‹",
            "headset-muted": "َ°ںژ",
            "phone": "َ°ڈ²",
            "phone-muted": "َ°·¯",
            "portable": "َ°ڈ²",
            "portable-muted": "َ°·¯",
            "car": "َ°„‹",
            "car-muted": "َ°¸œ",
            "default": [
                "َ°•؟",
                "َ°–€",
                "َ°•¾"
            ],
            "default-muted": [
                "َ°¸ˆ",
                "َ°–پ"
            ]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 100,
            "transition-left-to-right": false,
            "children-class": "power-drawer"
        },
        "modules": [
            "custom/power",
            "custom/power-shutdown",
            "custom/power-reboot",
            "custom/power-hibernate",
            "custom/power-suspend"
        ]
    },
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": false
    },
    "custom/power-shutdown": {
        "format": "َ°“›",
        "tooltip-format": "َ°“› Shutdown System",
        "on-click": "shutdown now"
    },
    "custom/power-reboot": {
        "format": "َ°‘“",
        "tooltip-format": "َ°‘“ Reboot System",
        "on-click": "reboot"
    },
    "custom/power-suspend": {
        "format": "َ°ڈ¤",
        "tooltip-format": "َ°ڈ¤ Suspend System",
        "on-click": "systemctl suspend"
    },
    "custom/power-hibernate": {
        "format": "َ°’²",
        "tooltip-format": "َ°’² Hibernate System",
        "on-click": "systemctl hibernate"
    },
    "group/nixos": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 100,
            "transition-left-to-right": true,
            "children-class": "nixos-drawer"
        },
        "modules": [
            "custom/nixos",
            "custom/nixos-build",
            "custom/nixos-upgrade",
            "custom/nixos-dry",
            "custom/nixos-powerwash",
            "custom/nixos-keybinds"
        ]
    },
    "custom/nixos": {
        "format": "َ±„…",
        "tooltip": false
    },
    "custom/nixos-build": {
        "format": "َ°²½",
        "tooltip-format": "َ°²½ Build NixOS",
        "on-click": "kitty --detach -d ~/Repositories/NixOS/ --hold sh -c \"just build\""
    },
    "custom/nixos-upgrade": {
        "format": "َ°¦—",
        "tooltip-format": "َ°¦— Upgrade NixOS",
        "on-click": "kitty --detach -d ~/Repositories/NixOS/ --hold sh -c \"just upgrade\""
    },
    "custom/nixos-dry": {
        "format": "َ±”¢",
        "tooltip-format": "َ±”¢ Dry Build NixOS",
        "on-click": "kitty --detach -d ~/Repositories/NixOS/ --hold sh -c \"just dry\""
    },
    "custom/nixos-powerwash": {
        "format": "َ°« ",
        "tooltip-format": "َ°«  Powerwash NixOS",
        "on-click": "kitty --detach -d ~/Repositories/NixOS/ --hold sh -c \"just powerwash\""
    },
    "custom/nixos-keybinds": {
        "format": "َ°¥»",
        "tooltip-format": "َ°¥» Display NixOS Keybinds",
        "on-click": "kitty --detach -d ~/Repositories/NixOS/ --hold sh -c \"cat ./.config/hypr/settings.keybindings.conf\""
    },
    "custom/notification": {
        "tooltip-format": "Notifications",
        "format": "{icon}",
        "format-icons": {
            "notification": "َ°‚ڑ",
            "none": "َ°‚œ",
            "dnd-notification": "َ°‚›",
            "dnd-none": "َ°ھ‘",
            "inhibited-notification": "َ°‚›",
            "inhibited-none": "َ°ھ‘",
            "dnd-inhibited-notification": "َ°‚›",
            "dnd-inhibited-none": "َ°ھ‘"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/settings-wallpaper": {
        "tooltip-format": "َ°¸‰ Change Wallpaper",
        "format": "َ°¸‰",
        "on-click": "~/.config/hypr/scripts.get-wallpaper.sh",
        "escape": true
    },
    "custom/open-application": {
        "format": "َ°œ„",
        "tooltip-format": "َ°œ„ Open Application Launcher",
        "on-click": "pkill rofi || rofi -show drun",
        "escape": true
    },
    "custom/spacer": {
        "format": " ",
        "tooltip": false
    }
}