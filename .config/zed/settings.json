// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "prettier": {
    "allowed": true,
  },
  "inlay_hints": {
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": true,
    "show_value_hints": true,
    "show_type_hints": true,
    "enabled": true,
  },
  "ui_font_size": 18.0,
  "theme": "System",
  // "notification_panel": {
  //   "button": false,
  //   "dock": "left",
  // },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "git_panel": {
    "tree_view": true,
    "button": true,
    "status_style": "icon",
    "dock": "left",
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
  },
  "search": {
    "button": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
    "button": true,
  },
  "debugger": {
    "button": false,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
  },
  "file_finder": {
    "file_icons": true,
    // "git_status": true,
  },
  "image_viewer": {},
  "colorize_brackets": true,
  "middle_click_paste": false,
  "indent_guides": {
    "active_line_width": 1,
    "line_width": 1,
    "background_coloring": "disabled",
    "coloring": "fixed",
    "enabled": false,
  },
  "toolbar": {
    "code_actions": true,
  },
  "gutter": {
    "runnables": false,
    "folds": true,
    "min_line_number_digits": 3,
    "line_numbers": true,
    "breakpoints": false,
  },
  "relative_line_numbers": "disabled",
  "autoscroll_on_clicks": false,
  "diff_view_style": "split",
  "outline_panel": {
    "indent_guides": {
      "show": "always",
    },
    "dock": "right",
    "button": true,
    "git_status": true,
  },
  "cursor_shape": "bar",
  "restore_on_startup": "launchpad",
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "icon_theme": "Material Icon Theme",
  "ui_font_family": "FiraCode Nerd Font Propo",
  "sticky_scroll": {
    "enabled": true,
  },
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_line_height": "comfortable",
  "project_panel": {
    "sort_mode": "directories_first",
    "file_icons": true,
    "entry_spacing": "comfortable",
    "dock": "left",
    "hide_root": true,
    "hide_hidden": false,
    "bold_folder_labels": false,
    "git_status": true,
    "folder_icons": true,
    "auto_fold_dirs": false,
  },
  "auto_update": false,
  "base_keymap": "VSCode",
  "show_whitespaces": "trailing",
  "soft_wrap": "editor_width",
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "working_directory": "current_project_directory",
    "shell": "system",
    "dock": "bottom",
    "max_scroll_history_lines": 2000,
    "cursor_shape": "bar",
  },
  "cursor_blink": false,
  "minimap": {
    "max_width_columns": 80,
    "show": "never",
  },
  "buffer_font_size": 18.0,
  "file_types": {
    "Shell Script": ["conf"],
  },
  "languages": {
    "Rust": {
      "formatter": {
        "external": {
          "command": "rustfmt",
          "arguments": [],
        },
      },
      "format_on_save": "on",
    },
  },
}
